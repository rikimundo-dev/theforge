# The Forge — plantilla .env (copiar a `.env` en la raíz o `apps/api/.env`). Ver README-LOCAL.md.
# Flags: activar 1|true|yes|on — desactivar 0|false|off|no (salvo que la variable indique otro criterio).

# NODE_ENV — Modo Node/Nest. Valores: development | production | test
NODE_ENV=development

# DATABASE_URL — PostgreSQL (Prisma). Formato: postgresql://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge

# REDIS_URL — BullMQ: si está vacío no hay cola (generate-deliverables síncrono). Ej.: redis://localhost:6379
REDIS_URL=

# PORT — Puerto HTTP del API Nest
PORT=3000

# CORS_ORIGINS — Orígenes permitidos (coma). En production es obligatorio definirlo
CORS_ORIGINS=

# WEB_DOMAIN — Host canónico del front (opcional)
WEB_DOMAIN=

# JWT_SECRET — Firma JWT; obligatorio en production
JWT_SECRET=

# JWT_EXPIRES_IN — Caducidad JWT (SignOptions, ej. 7d). Default en código: 7d
JWT_EXPIRES_IN=7d

# [DEPRECATED] EMAIL_OTP / AUTH_ALLOWED_OTP_EMAIL ya no se usan.
# Ahora el OTP se solicita con el email en el body del request y se valida
# contra la tabla `User` (multi-usuario). El primer admin se crea desde la UI
# (SetupView) cuando GET /auth/has-users devuelve false.
# EMAIL_OTP=
# AUTH_ALLOWED_OTP_EMAIL=

# SMTP_HOST — Servidor SMTP (obligatorio en production junto a USER/PASS)
SMTP_HOST=

# SMTP_PORT — Puerto SMTP. Default en código si falta: 587
SMTP_PORT=587

# SMTP_SECURE — 1 SSL directo; 0 STARTTLS (típ. con 587)
SMTP_SECURE=0

# SMTP_USER — Usuario SMTP
SMTP_USER=

# SMTP_PASS — Contraseña SMTP
SMTP_PASS=

# SMTP_FROM — Remitente From (si no tiene @, a veces se usa SMTP_USER)
SMTP_FROM=

# OTP_DEV_EXPOSE_CODE — 1|true|yes|on: POST /auth/otp/request devuelve devCode y NO envía correo (solo desarrollo).
# 0 u omitido: envía OTP por SMTP si está configurado; sin SMTP falla la petición.
OTP_DEV_EXPOSE_CODE=0

# FALKORDB_SDD_URL — Redis/Falkor SDD (si existe, tiene prioridad sobre FALKORDB_URL)
FALKORDB_SDD_URL=

# FALKORDB_URL — Redis/Falkor para grafo SDD. Default en código si ambas vacías: redis://localhost:6379
FALKORDB_URL=redis://localhost:6379

# OPENAI_EMBEDDING_DIM — Dimensión vector embeddings (evita probe al arranque). Típico OpenAI small: 1536
OPENAI_EMBEDDING_DIM=1536

# EMBEDDING_DIM — Alias de OPENAI_EMBEDDING_DIM
EMBEDDING_DIM=1536

# —— IA BYOK (claves por usuario en UI; NO usar OPENROUTER_API_KEY en servidor) ——
# TOKEN_MASTER_KEYS — JSON versión → clave AES-256 (32 bytes base64). Generar: openssl rand -base64 32
# Ej. primera clave: {"1":"<base64>"}  |  Rotación: {"1":"<vieja>","2":"<nueva>"}
# Guía completa y escenarios: README.md § "Cifrado de tokens BYOK"
TOKEN_MASTER_KEYS=

# TOKEN_ACTIVE_KEY_VERSION — Versión al cifrar tokens NUEVOS (debe existir en TOKEN_MASTER_KEYS).
# Descifrado usa tokenKeyVersion de cada fila; conviven v2+v3 si ambas claves están en el JSON.
# Migrar filas antiguas: npm run rotate-master-key (ver README y scripts/README.md)
TOKEN_ACTIVE_KEY_VERSION=1

# WIPE_BYOK_ON_START — 1 = en el próximo arranque del API borra ProviderInstance + UserProviderConfig
# (ciphertext irrecuperable tras cambiar TOKEN_MASTER_KEYS sin la clave anterior). Quitar tras un deploy.
# WIPE_BYOK_ON_START=1

# LLM_MAX_TOKENS — Tope de salida por petición (chat HTTP + grafo LangGraph MDD/DBGA). Default: 120000.
# OpenRouter con pocos créditos: si ves 402 "can only afford N", baja por debajo de N (p. ej. 4096).
# LLM_MAX_TOKENS=4096

# OPENROUTER_CHAT_FALLBACK_ON_429 — Con chatModelFallbacks en extras del usuario: 1 = fallback tras 429
# OPENROUTER_CHAT_FALLBACK_ON_429=

# OPENAI_EMBEDDING_DIM / EMBEDDING_DIM — Solo fallback de servidor si no hay dimensión en BYOK del usuario
# EMBEDDING_DIM=1536

# TAVILY_API_KEY — Búsqueda web Scout (opcional)
TAVILY_API_KEY=

# AGENT_EVALUATOR_LEGACY — Incluir evaluador legacy en respuesta. Default: desactivado (cualquier valor distinto de "true" no activa)
AGENT_EVALUATOR_LEGACY=false

# LANGGRAPH_RECURSION_LIMIT — Pasos LangGraph por invocación; rango 10–500. Default en código: 100
LANGGRAPH_RECURSION_LIMIT=100

# DEBUG_MDD_SECTION3 — Log §3 MDD. Default: desactivado
DEBUG_MDD_SECTION3=0

# MDD_PROPOSED_COMPONENT_DIAGRAM — Inyecta ### Diagrama de componentes propuesto en §2 del MDD greenfield. Default: 1
# MDD_PROPOSED_COMPONENT_DIAGRAM=0

# VITE_API_URL — Base API para Vite (build). Default en cliente: /api
VITE_API_URL=/api

# VITE_FORGE_GITHUB_REPO_URL — URL del repo en el footer del login (web). Opcional; default en código apunta a kreodevs/theforge
# VITE_FORGE_GITHUB_REPO_URL=https://github.com/tu-org/theforge

# THEFORGE_MCP_URL — URL MCP AriadneSpecs (Streamable HTTP). Vacío = TheForge MCP desconfigurado
THEFORGE_MCP_URL=

# MCP_AUTH_TOKEN — Bearer hacia el MCP (si aplica)
MCP_AUTH_TOKEN=

# MCP_X_M2M_TOKEN — Cabecera X-M2M-Token alternativa
MCP_X_M2M_TOKEN=

# THEFORGE_MCP_TIMEOUT_MS — Timeout ms por llamada JSON-RPC al MCP (herramientas rápidas). Default en código: 60000.
THEFORGE_MCP_TIMEOUT_MS=60000

# THEFORGE_MCP_ASK_CODEBASE_TIMEOUT_MS — Solo para tools/call ask_codebase (ingest puede tardar minutos).
# Si no se define, la API usa default 900000 (15 min). El resto de herramientas sigue usando THEFORGE_MCP_TIMEOUT_MS.
# THEFORGE_MCP_ASK_CODEBASE_TIMEOUT_MS=900000

# ── MCP M2M Auth ─────────────────────────────────────────────────────
# Secreto compartido entre theforge-mcp (servidor MCP) y la API NestJS.
# El MCP server envía este secreto a POST /auth/mcp-login y recibe un JWT.
# Debe ser el MISMO valor en ambos servicios (api + mcp).
# Rotación: cambiar el valor y redeployar ambos servicios.
MCP_M2M_SECRET=

# THEFORGE_API_URL — Base de la API Nest **desde el proceso del MCP** (`packages/mcp-server`, p. ej. Dokploy/Docker).
# Default en código: http://localhost:3000. En contenedor MCP, localhost es el propio contenedor → usar hostname del servicio API (ej. http://theforge-api:3000).
THEFORGE_API_URL=http://theforge-api:3000

# THEFORGE_LIST_PROJECTS_CACHE_MS — TTL ms caché list_known_projects. Default: 60000; 0 = sin caché
THEFORGE_LIST_PROJECTS_CACHE_MS=60000

# DEBUG_MCP — Log petición/respuesta MCP. Default: desactivado
DEBUG_MCP=0

# ── Hermes Agent Webhook ──────────────────────────────────────────────────
# HERMES_WEBHOOK_URL — URL del webhook proxy de Hermes Agent (para botón "Lanzar a Hermes")
# HERMES_API_KEY — API Key del proxy (Bearer token)
HERMES_WEBHOOK_URL=
HERMES_API_KEY=

# DEBUG_MCP_MAX_REQUEST_CHARS — Truncado log request. Default: 65536
DEBUG_MCP_MAX_REQUEST_CHARS=65536

# DEBUG_MCP_MAX_RESPONSE_CHARS — Truncado log response. Default: 32768
DEBUG_MCP_MAX_RESPONSE_CHARS=32768

# LEGACY_CODEBASE_DOC_MCP_DEBUG_UI — Devolver mcpDebugTrace en doc. partida. Default: 0
LEGACY_CODEBASE_DOC_MCP_DEBUG_UI=0

# LEGACY_AUTO_GENERATE_MDD_AFTER_CODEBASE_DOC — Tras doc. partida exitosa, invocar generateMdd y devolver mddContent. Default: 0
# LEGACY_AUTO_GENERATE_MDD_AFTER_CODEBASE_DOC=0

# LEGACY_MDD_EVIDENCE_PATHS_SAMPLE — Muestra de rutas en markdown MDD de partida (renderer legacy_mdd_v1). Default: 80
# LEGACY_MDD_EVIDENCE_PATHS_SAMPLE=80

# LEGACY_MDD_TABLE_ROW_SAMPLE — Filas máx. en tablas entities/api/business del renderer MDD. Default: 120
# LEGACY_MDD_TABLE_ROW_SAMPLE=120

# LEGACY_MDD_COMPONENT_DIAGRAM — Añade Diagrama de Componentes (Mermaid) a doc. partida y §2 del MDD legacy. Default: 1
# LEGACY_MDD_COMPONENT_DIAGRAM=0

# LEGACY_MDD_CODEBASE_DOC_PROMPT_MAX_CHARS — Tope del codebaseDoc inyectado en generateMdd (compactación inteligente). Default: 120000
# LEGACY_MDD_CODEBASE_DOC_PROMPT_MAX_CHARS=120000

# LEGACY_MDD_CODEBASE_DOC_PROMPT_PATHS — Máx. bullets de evidence_paths por repo en ese prompt. Default: 150
# LEGACY_MDD_CODEBASE_DOC_PROMPT_PATHS=150

# LEGACY_BRD_CODEBASE_DOC_PROMPT_MAX_CHARS — Tope del codebaseDoc en suggest-brd-from-codebase-doc (post-compactación). Default: 120000
# LEGACY_BRD_CODEBASE_DOC_PROMPT_MAX_CHARS=120000

# LEGACY_BRD_INVENTORY_THRESHOLD_CHARS — Si el doc compactado supera este tamaño (o hay muchas entidades), inventario previo 2 pasadas. Default: 28000
# LEGACY_BRD_INVENTORY_THRESHOLD_CHARS=28000

# LEGACY_CODEBASE_DOC_INDEX_SYNTHESIS — Con `raw_evidence`+determinista en doc. partida (modo clásico), segunda pasada
# `ask_codebase` con `responseMode: default` redacta un MDD en prosa desde evidencia + §5 semántica. Default: 1. 0 = solo anexo raw.
# LEGACY_CODEBASE_DOC_INDEX_SYNTHESIS=1

# LEGACY_CODEBASE_DOC_SYNTHESIS_INPUT_MAX_CHARS — Tope de caracteres de evidencia+semántica en el prompt de esa síntesis. Default: 28000
# LEGACY_CODEBASE_DOC_SYNTHESIS_INPUT_MAX_CHARS=28000

# LEGACY_EVIDENCE_FIRST_CONTEXT — Pipeline evidencia-primero. Default: activo (1)
LEGACY_EVIDENCE_FIRST_CONTEXT=1

# LEGACY_ASK_CODEBASE_EVIDENCE_FIRST — ask_codebase estructurado Ariadne: raw_evidence + deterministicRetriever + twoPhase. Default: 1. 0 = responseMode default (prosa).
LEGACY_ASK_CODEBASE_EVIDENCE_FIRST=1

# LEGACY_ANALYZER_COMPACT — Legacy Analyzer compacto. Default: activo (1)
LEGACY_ANALYZER_COMPACT=1

# LEGACY_ANALYZER_REQUIRE_GRAPH_HITS — No Analyzer si índice vacío. Default: activo (1)
LEGACY_ANALYZER_REQUIRE_GRAPH_HITS=1

# LEGACY_ANALYZER_ATTACH_RAW — Anexo evidencia bruta (debug). Default: 0
LEGACY_ANALYZER_ATTACH_RAW=0

# LEGACY_ANALYZER_INPUT_MAX_CHARS — Tope evidencia → Analyzer. Default: 14000
LEGACY_ANALYZER_INPUT_MAX_CHARS=14000

# LEGACY_SDD_INDEX_GATE — Cruce índice MCP vs SDD Falkor. Default: activo (1)
LEGACY_SDD_INDEX_GATE=1

# LEGACY_SDD_RICH_MIN_ENTITIES — Umbral entidades SDD “rico”. Default: 2
LEGACY_SDD_RICH_MIN_ENTITIES=2

# LEGACY_SDD_RICH_MIN_ENDPOINTS — Umbral endpoints SDD “rico”. Default: 2
LEGACY_SDD_RICH_MIN_ENDPOINTS=2

# LEGACY_SDD_INDEX_MIN_OVERLAP_RATIO — Solapamiento mínimo (0–1). Default: 0.28
LEGACY_SDD_INDEX_MIN_OVERLAP_RATIO=0.28

# LEGACY_SDD_MIN_ARTIFACTS_FOR_OVERLAP — Mínimo artefactos para chequeo solapamiento. Default: 2
LEGACY_SDD_MIN_ARTIFACTS_FOR_OVERLAP=2

# THEFORGE_CONTEXT_CACHE — Caché memoria contexto MCP. Default: activo (1)
THEFORGE_CONTEXT_CACHE=1

# THEFORGE_CONTEXT_CACHE_TTL_MS — TTL caché (mínimo efectivo 60000). Default: 1800000 (30 min)
THEFORGE_CONTEXT_CACHE_TTL_MS=1800000

# THEFORGE_CONTEXT_CACHE_MAX_ENTRIES — Máximo entradas (mínimo efectivo 8). Default: 80
THEFORGE_CONTEXT_CACHE_MAX_ENTRIES=80

# THEFORGE_CONTEXT_REVISION — Bump manual para invalidar caché (cualquier string; vacío = sin bump)
THEFORGE_CONTEXT_REVISION=

# LEGACY_SEMANTIC_SEARCH_LIMIT — Límite hits semantic_search MCP. Default: 80
LEGACY_SEMANTIC_SEARCH_LIMIT=80

# LEGACY_EVIDENCE_MAX_PATHS — Rutas candidatas (sin compact Analyzer: 35; con compact: 28 si no override). Default código: 35
LEGACY_EVIDENCE_MAX_PATHS=35

# LEGACY_EVIDENCE_FUNCTIONS_PATHS — Rutas con get_functions (20 sin compact; 16 compact). Default: 20
LEGACY_EVIDENCE_FUNCTIONS_PATHS=20

# LEGACY_EVIDENCE_FULL_FILE_PATHS — Extractos archivo completos (0 si Analyzer compact). Default: 3
LEGACY_EVIDENCE_FULL_FILE_PATHS=3

# LEGACY_SEMANTIC_SECTION_MAX_CHARS — Recorte bloque semantic (16000 normal; 4000 si compact y sin override). Default: 16000
LEGACY_SEMANTIC_SECTION_MAX_CHARS=16000

# LEGACY_CODEBASE_DOC_SEMANTIC_MAX_CHARS — Recorte §5 doc. partida. Default: 48000
LEGACY_CODEBASE_DOC_SEMANTIC_MAX_CHARS=48000

# LEGACY_SEMANTIC_KEEP_MARKDOWN_DOCS — Conservar **MarkdownDoc:** en semántica. Default: 0
LEGACY_SEMANTIC_KEEP_MARKDOWN_DOCS=0

# LEGACY_FILE_CONTENT_MAX_CHARS — Recorte get_file_content en evidencia. Default: 4000
LEGACY_FILE_CONTENT_MAX_CHARS=4000

# LEGACY_SYNTHESIS_INPUT_MAX_CHARS — Tope evidencia → síntesis ask_codebase. Default: 28000
LEGACY_SYNTHESIS_INPUT_MAX_CHARS=28000

# LEGACY_MDD_THEFORGE_CONTEXT_MAX_CHARS — Tope bloque TheForge en MDD coordinador. Default: 24000
LEGACY_MDD_THEFORGE_CONTEXT_MAX_CHARS=24000

# THEFORGE_CONTEXT_PREPEND_MAX_CHARS — Tope contexto TheForge en prompts de entregables. Default: 16000
THEFORGE_CONTEXT_PREPEND_MAX_CHARS=16000

# LEGACY_STAGED_DISCOVERY_MAX_TOOL_ROUNDS — Rondas tools descubrimiento escalonado. Default: 18
LEGACY_STAGED_DISCOVERY_MAX_TOOL_ROUNDS=18

# LEGACY_STAGED_DISCOVERY_OUTPUT_MAX_CHARS — Tope salida MDD agente. Default: 96000
LEGACY_STAGED_DISCOVERY_OUTPUT_MAX_CHARS=96000

# LEGACY_STAGED_DISCOVERY_SEMANTIC_FLOOR — Mínimo efectivo de `limit` en semantic_search del agente ReAct (evita que el LLM pase 10–20 y reciba índices pobres). Default: mismo valor que LEGACY_SEMANTIC_SEARCH_LIMIT (80 si no override).
# LEGACY_STAGED_DISCOVERY_SEMANTIC_FLOOR=80

# LEGACY_CODEBASE_DOC_PARALLEL_ASK — Modo clásico doc. partida: 1 = cuatro ask_codebase en paralelo (más rápido, más riesgo timeout). Default: 0 (secuencial).
# LEGACY_CODEBASE_DOC_PARALLEL_ASK=0

# LEGACY_DELIVERABLES_DEBUG — Logs Nest detallados por paso en POST …/legacy/generate-deliverables (además de lastDeliverablesDebug en JSON y legacyFlowState). Default: 0
# LEGACY_DELIVERABLES_DEBUG=0

# LEGACY_DELIVERABLES_INTER_STEP_DELAY_MS — Pausa entre cada paso LLM de la cascada entregables legacy (TPM/RPM). Default: 5000. 0 = sin pausa entre pasos.
# LEGACY_DELIVERABLES_INTER_STEP_DELAY_MS=5000

# LEGACY_DELIVERABLES_LARGE_MDD_THRESHOLD_CHARS — Si el MDD completo (antes de clip) supera este tamaño, cooldown único antes del primer entregable. Default: 80000. 0 = nunca.
# LEGACY_DELIVERABLES_LARGE_MDD_THRESHOLD_CHARS=80000

# LEGACY_DELIVERABLES_LARGE_MDD_COOLDOWN_MS — Milisegundos de espera cuando se supera el umbral anterior. Default: 20000
# LEGACY_DELIVERABLES_LARGE_MDD_COOLDOWN_MS=20000

# LEGACY_DELIVERABLES_MDD_MAX_CHARS — Tope del **texto efectivo** enviado a cada paso de entregables (rollup ensamblado o truncado). Default: 80000. Mínimo efectivo 12000.
# LEGACY_DELIVERABLES_MDD_MAX_CHARS=80000

# LEGACY_DELIVERABLES_MDD_ROLLUP — Si el MDD supera el tope anterior: 1 (default) = varias llamadas LLM por ventanas + ensamblado; 0 = truncar solo el inicio (legacy).
# LEGACY_DELIVERABLES_MDD_ROLLUP=1

# LEGACY_DELIVERABLES_ROLLUP_CHUNK_CHARS — Tamaño objetivo de cada ventana del MDD (corte preferente en ##). Default: 40000
# LEGACY_DELIVERABLES_ROLLUP_CHUNK_CHARS=40000

# LEGACY_DELIVERABLES_ROLLUP_MAX_CHUNKS — Máximo de ventanas por rollup. Default: 32
# LEGACY_DELIVERABLES_ROLLUP_MAX_CHUNKS=32

# LEGACY_DELIVERABLES_SECTION_MERGE — Genera entregables por **ventanas del MDD** (§1–§7), ensamblado + checklist + conformanceCheck (si aplica) + reparación opcional. Valores: `all` (default), `blueprint` (solo Blueprint), `auto` (elige por entregable según estimación de tokens del prompt monolítico; ver `legacy-deliverables-strategy/`), `0`/`off` (desactivado → monolítico).
# LEGACY_DELIVERABLES_SECTION_MERGE=all

# LEGACY_DELIVERABLES_STRATEGY_AUTO_USER_PROMPT_TOKEN_MAX — Con `SECTION_MERGE=auto`: por encima de este tope estimado (tokens del user prompt monolítico) se intenta section merge. Default: 28000
# LEGACY_DELIVERABLES_STRATEGY_AUTO_USER_PROMPT_TOKEN_MAX=28000

# LEGACY_DELIVERABLES_STRATEGY_CHARS_PER_TOKEN — Fallback chars→tokens si tiktoken no carga. Default: 4
# LEGACY_DELIVERABLES_STRATEGY_CHARS_PER_TOKEN=4

# LEGACY_DELIVERABLES_STRATEGY_USE_TIKTOKEN — Cuenta tokens con `js-tiktoken` (import dinámico ESM). `0`/`off` = solo heurística chars/ratio. Default: activo
# LEGACY_DELIVERABLES_STRATEGY_USE_TIKTOKEN=1

# LEGACY_DELIVERABLES_STRATEGY_TIKTOKEN_ENCODING — BPE tiktoken (p. ej. cl100k_base, o200k_base). Si falla, se intenta cl100k_base.
# LEGACY_DELIVERABLES_STRATEGY_TIKTOKEN_ENCODING=cl100k_base

# LEGACY_DELIVERABLES_STRATEGY_TIKTOKEN_INSTRUCTION_OVERHEAD_TOKENS — Suma al conteo del user simulado (aprox. system + plantilla). Default: 450
# LEGACY_DELIVERABLES_STRATEGY_TIKTOKEN_INSTRUCTION_OVERHEAD_TOKENS=450

# LEGACY_DELIVERABLES_LLM_429_MAX_RETRIES — Reintentos por paso ante 429 / resource exhausted. Default: 5. 0 = sin reintentos.
# LEGACY_DELIVERABLES_LLM_429_MAX_RETRIES=5

# LEGACY_DELIVERABLES_LLM_429_BASE_DELAY_MS — Backoff base (ms) si el upstream no envía Retry-After. Default: 15000 (×2 por intento, tope 180s).
# LEGACY_DELIVERABLES_LLM_429_BASE_DELAY_MS=15000

# --- Ingest Ariadne (operadores; no las lee apps/api salvo doc) ---
# CHAT_TELEMETRY_LOG — Log telemetría alcance chat en ingest. Default ingest: desactivado salvo 1
# CHAT_TELEMETRY_LOG=0
# CHAT_TWO_PHASE — JSON retrieval dos fases en ingest. Default: según despliegue Ariadne
# CHAT_TWO_PHASE=0
# CHAT_EVIDENCE_FIRST_MAX_CHARS — Tope evidencia evidence_first en ingest. Ejemplo documentado Ariadne: 18000
# CHAT_EVIDENCE_FIRST_MAX_CHARS=18000

# PRISMA_RESOLVE_ROLLED_BACK — Nombre migración rolled-back (solo cuando Prisma lo pida); vacío = no usar
PRISMA_RESOLVE_ROLLED_BACK=

# WAIT_FOR_POSTGRES_ATTEMPTS — Espera Postgres (entrypoint). Default script: 90
WAIT_FOR_POSTGRES_ATTEMPTS=90

# WAIT_FOR_POSTGRES_DELAY_MS — Intervalo entre intentos. Default script: 1000
WAIT_FOR_POSTGRES_DELAY_MS=1000

# CLEAN_SPEC_PROJECT_ID — Script clean-spec.ts. Default en script: 3
CLEAN_SPEC_PROJECT_ID=3

# --- Desarrollo local (pnpm dev / dev:local) ---
# ensure-infra.js levanta Postgres :5432, Falkor :6379, Redis cola :6381
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge
FALKORDB_SDD_URL=redis://localhost:6379
FALKORDB_URL=redis://localhost:6379
REDIS_URL=redis://localhost:6381
JWT_SECRET=local-dev-jwt-secret
# TOKEN_MASTER_KEYS={"1":"<openssl rand -base64 32>"}
# TOKEN_ACTIVE_KEY_VERSION=1

# --- Docker / Dokploy (docker-compose pull) ---
# Builds usan ECR Public fijo en Dockerfiles (node/nginx). Override solo postgres/redis si hace falta:
# POSTGRES_IMAGE=postgres:15-alpine
# REDIS_IMAGE=redis:7-alpine
# BUILD_CACHE_BUST=94
