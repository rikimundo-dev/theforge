# The Forge — variables de entorno
# Copiar a `.env` en la raíz del repo (o a `apps/api/.env` si solo corres la API).
# Ver README-LOCAL.md para ejecución en local.

# Entorno de ejecución (típicamente lo fija el host: development | production).
# NODE_ENV=development

# Base de datos (Prisma + API). Obligatorio en local.
DATABASE_URL=postgresql://theforge:theforge@localhost:5432/theforge

# Cola BullMQ (opcional). Si está definido, POST /projects/:id/generate-deliverables encola la cascada y evita timeouts HTTP.
# Docker Compose define por defecto redis://theforge-redis-queue:6379 para el servicio API.
# REDIS_URL=redis://localhost:6379

# API (NestJS)
PORT=3000
# Orígenes permitidos CORS (coma). En producción es obligatorio.
# En docker-compose, el default incluye https://theforge.kreoint.mx, WEB_DOMAIN y localhost (Vite).
# En Dokploy puedes sobreescribir con la lista exacta, p. ej. solo https://theforge.kreoint.mx
# CORS_ORIGINS=https://theforge.kreoint.mx,http://localhost:5173,http://127.0.0.1:5173
# WEB_DOMAIN=theforge.local

# Auth — OTP solo se envía/valida para UN correo (producción: obligatorio definir EMAIL_OTP o AUTH_ALLOWED_OTP_EMAIL).
JWT_SECRET=
# JWT_EXPIRES_IN=7d
# Correo único para OTP (recomendado en Docker/Dokploy). Tiene prioridad sobre AUTH_ALLOWED_OTP_EMAIL.
EMAIL_OTP=tu-email@dominio.com
# AUTH_ALLOWED_OTP_EMAIL=tu-email@dominio.com
# SMTP — en NODE_ENV=production es obligatorio (OTP solo por correo). En dev, sin SMTP el código va al log.
# Ejemplo producción (Dokploy / docker-compose pasan estas vars al contenedor API):
# SMTP_HOST=mail.kreoint.mx
# SMTP_PORT=587
# SMTP_SECURE=0
# SMTP_USER=hola@kreoint.mx
# SMTP_PASS=                    # secreto; definir solo en el entorno del servidor
# SMTP_FROM=Servicio de aplicaciones   # si no incluye @, se usa SMTP_USER como dirección

# Grafo SDD (FalkorDB / Redis). Por defecto en código: redis://localhost:6379 si no hay variable.
# En docker-compose: FALKORDB_SDD_URL y FALKORDB_URL apuntan al servicio theforge-falkor-sdd.
# FALKORDB_SDD_URL=redis://localhost:6380
# FALKORDB_URL=redis://localhost:6380

# Memoria vectorial (GraphMemory): dimensión del embedding sin llamar a la API al arranque (útil si hay 429 / cuota).
# OPENAI_EMBEDDING_DIM=1536
# EMBEDDING_DIM=1536

# IA — proveedor activo de chat (misma familia de claves que siempre).
# Valores: openai | google | gemini | kimi | moonshot (gemini→google, moonshot→kimi).
AI_PROVIDER=openai

# Clave API para proveedores openai/kimi (OpenAI oficial, Moonshot/Kimi, u otro endpoint compatible).
AI_API_KEY=
# OPENAI_API_KEY=   # alias retrocompatible (misma semántica que AI_API_KEY)

# Solo OpenAI-compatible (openai | kimi): base y modelo de chat. Kimi defaults: https://api.moonshot.ai/v1 + kimi-k2.5
# OPENAI_BASE_URL=https://api.moonshot.ai/v1
# OPENAI_CHAT_MODEL=gpt-4o

# Google / Gemini (si el proveedor activo es google):
# GOOGLE_GENERATIVE_AI_API_KEY=
# Mismo secreto, alias retrocompatible:
# GEMINI_API_KEY=
# Modelo de chat (opcional):
# GOOGLE_CHAT_MODEL=gemini-2.0-flash
# GEMINI_CHAT_MODEL=gemini-2.0-flash

# Embeddings (grafo Falkor): por defecto OpenAI text-embedding con chat openai; Gemini con chat google.
# Con kimi: si también tienes clave Google, se usan embeddings Gemini; si no, OpenAI oficial (falla suave si la clave es solo Moonshot).
# Override opcional: openai | google (google incluye modelo gemini-embedding-001 en código).
# LLM_EMBEDDINGS_PROVIDER=

# DBGA / AiAnalysis (Scout: búsqueda). Scrape usa Cheerio (sin API key).
# TAVILY_API_KEY=

# Orquestador: si true, incluye evaluador legacy + crítica en la respuesta del chat (más tokens).
# AGENT_EVALUATOR_LEGACY=true

# LangGraph: límite de pasos por invocación (MDD con Manager / pipeline largo). Default en código 100; el SDK usa 25 si no se pasa.
# Rango permitido 10–500.
# LANGGRAPH_RECURSION_LIMIT=100

# Debug: volcado de §3 MDD al log (solo desarrollo).
# DEBUG_MDD_SECTION3=1

# Web (Vite). Opcional: URL base del API en build de producción.
# VITE_API_URL=/api

# TheForge MCP / AriadneSpecs (proyectos legacy). Opcional: si no está configurado, listKnownProjects devuelve vacío.
# THEFORGE_MCP_URL=https://ariadne.kreoint.mx/mcp
# MCP_AUTH_TOKEN=           # Bearer token (si el servidor requiere auth)
# MCP_X_M2M_TOKEN=          # Alternativa: X-M2M-Token (AriadneSpecs)
# THEFORGE_MCP_TIMEOUT_MS=60000   # Umbral por llamada MCP (ask_codebase, semantic_search). La doc. de partida usa 4 ask_codebase en paralelo + fallback; si todo vuelve vacío, sube a 120000–300000.
# THEFORGE_LIST_PROJECTS_CACHE_MS=60000   # TTL lista list_known_projects en API (resolución id workspace ↔ roots). 0 = sin caché.
# DEBUG_MCP=0               # 1 o true: log en API de cada llamada/respuesta HTTP al MCP (Ariadne). Opcional: DEBUG_MCP_MAX_REQUEST_CHARS, DEBUG_MCP_MAX_RESPONSE_CHARS
# LEGACY_CODEBASE_DOC_MCP_DEBUG_UI=0   # 1 o true: la generación de doc. partida devuelve mcpDebugTrace (petición/respuesta JSON-RPC) para el panel de debug en MDD Inicial (LEGACY).

# Legacy / contexto TheForge (evidencia primero). Default: pipeline activo.
# LEGACY_EVIDENCE_FIRST_CONTEXT=0   # desactiva: vuelve a ask_codebase x3 + semántica clásica
# Fase 3 — Legacy Analyzer compacto (menos tokens; sin volcar archivos completos en el prompt final). Default: activo.
# LEGACY_ANALYZER_COMPACT=0
# Si semantic_search devuelve vacío para el projectId, no invocar Analyzer (evita mensaje «sin datos en índice»); fallback clásico. Default: 1.
# LEGACY_ANALYZER_REQUIRE_GRAPH_HITS=0
# LEGACY_ANALYZER_ATTACH_RAW=1   # adjunta anexo recortado tras el analizador (debug)
# LEGACY_ANALYZER_INPUT_MAX_CHARS=14000
# Cruce índice MCP vs grafo SDD antes de síntesis (default: activo). Desactivar: LEGACY_SDD_INDEX_GATE=0
# LEGACY_SDD_INDEX_GATE=1
# Umbrales del gate índice ↔ SDD (legacy-index-sdd-alignment.util.ts). Defaults en código si no se definen.
# LEGACY_SDD_RICH_MIN_ENTITIES=2
# LEGACY_SDD_RICH_MIN_ENDPOINTS=2
# LEGACY_SDD_INDEX_MIN_OVERLAP_RATIO=0.28
# LEGACY_SDD_MIN_ARTIFACTS_FOR_OVERLAP=2
# Caché de contexto MCP en API (memoria). THEFORGE_CONTEXT_REVISION=bump para invalidar sin esperar TTL.
# THEFORGE_CONTEXT_CACHE=0
# THEFORGE_CONTEXT_CACHE_TTL_MS=1800000
# THEFORGE_CONTEXT_CACHE_MAX_ENTRIES=80
# LEGACY_SEMANTIC_SEARCH_LIMIT=80   # Resultados por query hacia MCP semantic_search (The Forge). Sin tope “infinito” aquí: el MCP (Ariadne) ya limita; sube si aún corta evidencia.
# LEGACY_EVIDENCE_MAX_PATHS=35
# LEGACY_EVIDENCE_FUNCTIONS_PATHS=20
# LEGACY_EVIDENCE_FULL_FILE_PATHS=3
# LEGACY_SEMANTIC_SECTION_MAX_CHARS=16000
# LEGACY_CODEBASE_DOC_SEMANTIC_MAX_CHARS=48000   # Solo «MDD Inicial / doc. partida»: recorte del bloque §5 (semantic_search); el genérico sigue siendo LEGACY_SEMANTIC_SECTION_MAX_CHARS.
# LEGACY_SEMANTIC_KEEP_MARKDOWN_DOCS=0   # 1: conservar en doc. partida las líneas **MarkdownDoc:** del MCP (default 0: omitir — suelen ser PRD/diseño, no código)
# LEGACY_FILE_CONTENT_MAX_CHARS=4000
# LEGACY_SYNTHESIS_INPUT_MAX_CHARS=28000
# LEGACY_MDD_THEFORGE_CONTEXT_MAX_CHARS=24000

# Modelo C4 en contexto legacy (Blueprint / entregables): MCP `get_c4_model` (requiere JWT Nest en el proceso MCP hacia GraphService). Default: activo.
# LEGACY_C4_CONTEXT=0
# LEGACY_C4_MAX_CHARS=5000
# Tope del bloque TheForge inyectado en prompts legacy (prepend); subir si combinas C4 + evidencia larga.
# THEFORGE_CONTEXT_PREPEND_MAX_CHARS=16000

# Ingest Ariadne (lado servidor MCP): telemetría y dos fases del chat
# CHAT_TELEMETRY_LOG=1
# CHAT_TWO_PHASE=0   # desactiva JSON retrieval antes del contexto bruto (solo si controlas el ingest)
# CHAT_EVIDENCE_FIRST_MAX_CHARS=18000   # con responseMode evidence_first (ask_codebase / The Forge)

# P3009: migración atascada — desbloquear antes de deploy (ej. 20260319130000_agent_checkpoint_mdd_stage)
# PRISMA_RESOLVE_ROLLED_BACK=20260319130000_agent_checkpoint_mdd_stage

# Docker / entrypoint API (wait-for-postgres en imagen API). Defaults en scripts si no se definen.
# WAIT_FOR_POSTGRES_ATTEMPTS=90
# WAIT_FOR_POSTGRES_DELAY_MS=1000

# Script de mantenimiento (no arranque API)
# CLEAN_SPEC_PROJECT_ID=3
