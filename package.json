{
  "name": "theforge",
  "version": "0.4.0",
  "private": true,
  "author": "Jorge Correa <jcorrea@e-personal.net>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:local": "node scripts/ensure-infra.js && pnpm run dev",
    "dev:api": "node scripts/ensure-infra.js && turbo run dev --filter=@theforge/api",
    "dev:web": "turbo run dev --filter=@theforge/web",
    "compose:local": "docker compose -f docker-compose.yml -f docker-compose.local.yml up --build",
    "compose:local:config": "docker compose -f docker-compose.yml -f docker-compose.local.yml config",
    "compose:coolify:config": "docker compose -f docker-compose.yml -f docker-compose.coolify.yml config",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:types": "turbo run test:types",
    "db:generate": "turbo run db:generate --filter=@theforge/database",
    "db:push": "turbo run db:push --filter=@theforge/database",
    "db:migrate": "turbo run db:migrate --filter=@theforge/database",
    "rotate-master-key": "tsx scripts/rotate-master-key.ts",
    "setup:githooks": "sh scripts/setup-githooks.sh"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "turbo": "^2.3.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@radix-ui/react-tooltip": "^1.2.8"
  }
}
