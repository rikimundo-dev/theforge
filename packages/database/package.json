{
  "name": "@theforge/database",
  "version": "0.0.0",
  "private": true,
  "author": "Jorge Correa <jcorrea@e-personal.net>",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc && node -e \"require('fs').cpSync('src/generated', 'dist/generated', { recursive: true })\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:resolve-project-type": "prisma migrate resolve --applied 20250311000000_add_project_type_relic",
    "db:resolve-relic-to-theforge": "prisma migrate resolve --applied 20260319190000_rename_relic_to_theforge"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "prisma": "^5.22.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.6.3"
  },
  "peerDependencies": {
    "@theforge/config": "*"
  }
}
