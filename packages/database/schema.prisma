generator client {
  provider      = "prisma-client-js"
  output        = "./src/generated"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Usuario de la aplicación (identidad JWT tras OTP). Propietario de proyectos y sesiones.
model User {
  id        String    @id @default(uuid())
  email     String    @unique
  createdAt DateTime  @default(now())
  /// Secret MCP M2M: criptográfico (32 bytes, 64 hex chars). Único por usuario.
  /// Usado para autenticar peticiones del MCP server como este usuario.
  /// Generado automáticamente en el primer login OTP. Roteable desde la UI.
  mcpSecret String?   @unique
  projects  Project[]
  sessions  Session[]
}

enum ProjectType {
  NEW
  LEGACY
}

/// Política de adopción SDD: define qué entregables y qué reglas de semáforo aplican al proyecto.
enum ComplexityLevel {
  LOW
  MEDIUM
  HIGH
}

/// Ciclo de vida agéntico: cada proyecto avanza por etapas (MDD, cambios legacy, auditoría, etc.).
/// Entregables SDD "constitucionales" (MDD, semáforo, estimación) viven por etapa, no en Project.
/// `isLegacy` + `theforgeProjectId` en Stage permiten enrutar sin releer Project en cada iteración.
model Stage {
  id               String       @id @default(uuid())
  projectId        String
  project          Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// Orden dentro del proyecto (1 = primera etapa activa).
  ordinal          Int          @default(1)
  /// Clave estable p. ej. MDD_DRAFT, LEGACY_IMPACT, EVALUATOR.
  key              String?
  name             String?
  /// Estado del workflow de la etapa (borrador, activa, cerrada).
  workflowStatus   StageStatus  @default(DRAFT)
  /// Constitución SDD (markdown): Master Design Document de 7 secciones para esta etapa.
  mddContent       String?      @db.Text
  /// BRD (markdown): problema, KPIs, alcance de negocio — fase previa al MDD técnico.
  brdContent            String?   @db.Text
  /// Manual To-Be (markdown): lógica y comportamiento deseado.
  toBeManualContent     String?   @db.Text
  /// Mapa / manual As-Is (markdown); útil en legacy o documentación del proceso actual.
  asIsManualContent     String?   @db.Text
  /// Marca de aprobación cliente (HITL) del BRD.
  brdApprovedAt         DateTime?
  /// Marca de aprobación cliente (HITL) del To-Be.
  toBeApprovedAt        DateTime?
  /// Semáforo SDD (ROJO / AMARILLO / VERDE) derivado del MDD.
  status           Status       @default(ROJO)
  precisionScore   Int          @default(0)
  estimation       Estimation?
  /// Redundancia intencional con `Project.projectType === LEGACY` para queries y checkpoints por etapa.
  isLegacy         Boolean      @default(false)
  /// Override opcional; si null, aplica `Project.theforgeProjectId`.
  theforgeProjectId   String?
  /// Memoria de trabajo (corto plazo): último contexto / scratch del agente (JSON).
  shortTermContext Json?
  episodicMemories EpisodicMemory[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([projectId, ordinal])
  @@index([projectId])
}

/// Memoria episódica (largo plazo por etapa): trazas de razonamiento, ADRs, críticas del Evaluator (Reflexion).
model EpisodicMemory {
  id        String             @id @default(uuid())
  stageId   String
  stage     Stage              @relation(fields: [stageId], references: [id], onDelete: Cascade)
  kind      EpisodicMemoryKind
  content   String             @db.Text
  metadata  Json?
  createdAt DateTime           @default(now())

  @@index([stageId, createdAt])
}

enum StageStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
  SUPERSEDED
}

enum EpisodicMemoryKind {
  REASONING_TRACE
  ARCHITECTURE_DECISION
  REFLEXION_FEEDBACK
  EVALUATOR_REJECTION
  TOOL_OUTPUT
}

model Project {
  id               String       @id @default(uuid())
  userId           String
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  /// Nivel de complejidad / riesgo: gobierna semáforo y qué documentos son obligatorios (efectivo tras confirmación).
  complexity       ComplexityLevel @default(HIGH)
  /// Propuesta HITL pendiente: { level, planSummary, reason } hasta que el usuario confirme en el chat.
  complexityPending Json?
  projectType      ProjectType  @default(NEW)
  /// Si true, el API bloquea MDD técnico (§3+) hasta BRD y Manual To-Be aprobados en la etapa activa. LEGACY suele ir en false hasta una fase de mejora; NEW en true por defecto.
  requireBrdTobeGate Boolean     @default(true)
  theforgeProjectId   String?
  hasUxTeam        Boolean      @default(false)
  stages           Stage[]
  sessions         Session[]
  figmaMapping     Json?
  dbgaContent          String?   @db.Text
  specContent          String?   @db.Text
  architectureContent  String?   @db.Text
  useCasesContent      String?   @db.Text
  userStoriesContent   String?   @db.Text
  blueprintContent     String?   @db.Text
  tasksContent         String?   @db.Text
  apiContractsContent  String?   @db.Text
  logicFlowsContent    String?   @db.Text
  infraContent         String?   @db.Text
  uxUiGuideContent     String?   @db.Text
  phase0SummaryContent String?   @db.Text
  /// Estado del flujo legacy: { description?, filesToModify?, questions?, answers? }
  legacyFlowState      Json?
  agentCheckpoints     AgentStateCheckpoint[]
  createdAt            DateTime  @default(now())

  @@index([userId])
}

/// Hilo LangGraph: Fase 0 / DBGA usa `mddStageId` vacío; flujo MDD Manager por etapa usa el id de `Stage`.
model AgentStateCheckpoint {
  id        String   @id @default(uuid())
  threadId  String   @unique
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// "" = DBGA/Benchmark compartido; UUID de Stage = Manager MDD de esa etapa.
  mddStageId String  @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, mddStageId])
  @@index([projectId])
}

/// Memoria semántica: preferencias arquitectónicas extraídas al aprobar un MDD.
/// Se inyectan al inicio de Fase 0 para alinear el benchmark al estilo del usuario.
model ArchitecturalPreference {
  id         String   @id @default(uuid())
  projectId  String?
  summary    String   @db.Text
  createdAt  DateTime @default(now())
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chatLog     Json
  contextStep String
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([projectId])
}

model Estimation {
  id             String   @id @default(uuid())
  stageId        String   @unique
  stage          Stage    @relation(fields: [stageId], references: [id], onDelete: Cascade)
  totalHours    Float
  totalMxn      Float
  teamStructure Json
}

enum Status {
  ROJO
  AMARILLO
  VERDE
}
